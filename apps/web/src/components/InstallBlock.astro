---
import CopyButton from './CopyButton.astro';

const {
	command,
	label = 'Install',
	description,
} = Astro.props as {
	command: string;
	label?: string;
	description?: string;
};
---

<div class="install-block">
	<div class="install-meta">
		<p class="eyebrow">{label}</p>
		{description && <p class="install-description">{description}</p>}
	</div>
	<div class="command-row">
		<code>{command}</code>
		<CopyButton value={command} label="Copy" />
	</div>
</div>
