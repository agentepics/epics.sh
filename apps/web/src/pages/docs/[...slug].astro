---
import { getCollection, render } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import MarkdownActions from '../../components/MarkdownActions.astro';
import { docSlug } from '../../lib/docs';

export async function getStaticPaths() {
	const docs = await getCollection('docs');
	return docs.map((entry) => ({
		params: {
			slug: docSlug(entry.id),
		},
		props: { entry },
	}));
}

const { entry } = Astro.props as {
	entry: Awaited<ReturnType<typeof getCollection<'docs'>>>[number];
};

const { Content } = await render(entry);
const slug = docSlug(entry.id);
const mdUrl = `/docs/${slug}.md`;
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<section class="docs-article">
		<div class="docs-article-header">
			<div>
				<p class="doc-kicker">{entry.data.section}</p>
				<h1>{entry.data.title}</h1>
				<p class="meta-line">{entry.data.description}</p>
			</div>
			<MarkdownActions mdUrl={mdUrl} />
		</div>
		<hr />
		<Content />
	</section>
</BaseLayout>
