---
import { getCollection, render } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const docs = await getCollection('docs');
	return docs.map((entry) => ({
		params: {
			slug: entry.id.replace(/\.mdx?$/, '').replace(/\/index$/, ''),
		},
		props: { entry },
	}));
}

const { entry } = Astro.props as {
	entry: Awaited<ReturnType<typeof getCollection<'docs'>>>[number];
};

const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<section class="docs-article">
		<p class="doc-kicker">{entry.data.section}</p>
		<h1>{entry.data.title}</h1>
		<p class="meta-line">{entry.data.description}</p>
		<hr />
		<Content />
	</section>
</BaseLayout>
